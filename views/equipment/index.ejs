<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1>Equipment</h1>
  <a class="btn btn-add" href="/equipment/new">Add Equipment</a>
</div>

<div class="card table-wrap">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Category</th>
        <th>Quantity</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% equipment.forEach((item) => { %>
        <tr>
          <td><%= item.id %></td>
          <td><%= item.equipment_name %></td>
          <td><%= item.category %></td>
          <td><%= item.quantity %></td>
          <td><%= item.status %></td>
          <td class="actions">
            <a class="btn btn-primary" href="/equipment/<%= item.id %>">Show</a>
            <a class="btn btn-warning" href="/equipment/<%= item.id %>/edit">Edit</a>
            <form action="/equipment/<%= item.id %>?_method=DELETE" method="POST" data-confirm="Delete this equipment?">
              <button class="btn btn-delete" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
