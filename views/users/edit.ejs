<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1>Edit User</h1>
</div>
<div class="card">
  <form action="/users/<%= user.id %>?_method=PUT" method="POST" class="form-grid">
    <div class="form-group">
      <label for="full_name">Full Name</label>
      <input id="full_name" name="full_name" value="<%= user.full_name %>" required />
    </div>
    <div class="form-group">
      <label for="student_id">Student ID</label>
      <input id="student_id" name="student_id" value="<%= user.student_id %>" required />
    </div>
    <div class="form-group">
      <label for="phone">Phone</label>
      <input id="phone" name="phone" value="<%= user.phone %>" required />
    </div>
    <div class="form-group">
      <label for="username">Username</label>
      <input id="username" name="username" value="<%= user.username %>" required />
    </div>
    <div class="form-group">
      <label for="password">New Password (optional)</label>
      <input id="password" name="password" type="password" />
    </div>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <div class="form-group">
        <label for="role">Role</label>
        <select id="role" name="role">
          <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>user</option>
          <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>admin</option>
        </select>
      </div>
    <% } %>
    <div class="actions">
      <button type="submit" class="btn btn-primary">Update</button>
      <a class="btn btn-cancel" href="<%= currentUser && currentUser.role === 'admin' ? '/users' : `/users/${user.id}` %>">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
