<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1>Create User</h1>
</div>
<div class="card">
  <form action="/users" method="POST" class="form-grid">
    <div class="form-group">
      <label for="full_name">Full Name</label>
      <input id="full_name" name="full_name" required />
    </div>
    <div class="form-group">
      <label for="student_id">Student ID</label>
      <input id="student_id" name="student_id" required />
    </div>
    <div class="form-group">
      <label for="phone">Phone</label>
      <input id="phone" name="phone" required />
    </div>
    <div class="form-group">
      <label for="username">Username</label>
      <input id="username" name="username" required />
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required />
    </div>
    <div class="form-group">
      <label for="role">Role</label>
      <select id="role" name="role">
        <option value="user">user</option>
        <option value="admin">admin</option>
      </select>
    </div>
    <div class="actions">
      <button type="submit" class="btn btn-add">Create</button>
      <a class="btn btn-cancel" href="/users">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
