<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1>Users</h1>
  <a class="btn btn-add" href="/users/new">Add User</a>
</div>

<div class="card table-wrap">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Full Name</th>
        <th>Student ID</th>
        <th>Phone</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach((user) => { %>
        <tr>
          <td><%= user.id %></td>
          <td><%= user.full_name %></td>
          <td><%= user.student_id %></td>
          <td><%= user.phone %></td>
          <td class="actions">
            <a class="btn btn-primary" href="/users/<%= user.id %>">Show</a>
            <a class="btn btn-warning" href="/users/<%= user.id %>/edit">Edit</a>
            <form action="/users/<%= user.id %>?_method=DELETE" method="POST" data-confirm="Delete this user?">
              <button class="btn btn-delete" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
