<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title ? `${title} | YeumEasy` : 'YeumEasy' %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <nav class="navbar">
      <div class="container navbar-inner">
        <a href="/" class="brand">YeumEasy</a>
        <div class="nav-links">
          <% if (currentUser) { %>
            <a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a>
            <a href="/users/<%= currentUser.id %>" class="<%= path.startsWith('/users') ? 'active' : '' %>">My Profile</a>
            <a href="/borrows" class="<%= path.startsWith('/borrows') || path.startsWith('/borrow-details') ? 'active' : '' %>">My Borrow</a>
            <% if (currentUser.role === 'admin') { %>
              <a href="/users" class="<%= path.startsWith('/users') ? 'active' : '' %>">Users</a>
              <a href="/equipment" class="<%= path.startsWith('/equipment') ? 'active' : '' %>">Equipment</a>
              <a href="/reports/borrow-by-date" class="<%= path.startsWith('/reports') ? 'active' : '' %>">Reports</a>
            <% } %>
            <form action="/logout" method="POST" style="display: inline;">
              <button type="submit" class="btn btn-cancel">Logout</button>
            </form>
          <% } else { %>
            <a href="/login" class="<%= path === '/login' ? 'active' : '' %>">Login</a>
          <% } %>
        </div>
      </div>
    </nav>
    <main class="container">
      <%- include('flash') %>
