<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1><%= currentUser && currentUser.role === 'admin' ? 'Borrow Details' : 'My Borrow Details' %></h1>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <a class="btn btn-add" href="/borrow-details/new">Add Borrow Detail</a>
  <% } %>
</div>

<div class="card table-wrap">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Borrow ID</th>
        <th>User</th>
        <th>Equipment</th>
        <th>Amount</th>
        <th>Returned</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% details.forEach((detail) => { %>
        <tr>
          <td><%= detail.id %></td>
          <td><%= detail.borrow_id %></td>
          <td><%= detail.Borrow && detail.Borrow.User ? detail.Borrow.User.full_name : '-' %></td>
          <td><%= detail.Equipment ? detail.Equipment.equipment_name : '-' %></td>
          <td><%= detail.amount %></td>
          <td><%= detail.returned_amount %></td>
          <td class="actions">
            <a class="btn btn-primary" href="/borrow-details/<%= detail.id %>">Show</a>
            <% if (currentUser && currentUser.role === 'admin') { %>
              <a class="btn btn-warning" href="/borrow-details/<%= detail.id %>/edit">Edit</a>
              <form action="/borrow-details/<%= detail.id %>?_method=DELETE" method="POST" data-confirm="Delete this borrow detail?">
                <button class="btn btn-delete" type="submit">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
