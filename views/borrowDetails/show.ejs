<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1>Borrow Detail Item</h1>
  <div class="actions">
    <a class="btn btn-warning" href="/borrow-details/<%= detail.id %>/edit">Edit</a>
    <a class="btn btn-cancel" href="/borrow-details">Back</a>
  </div>
</div>
<div class="card">
  <p><strong>ID:</strong> <%= detail.id %></p>
  <p><strong>Borrow ID:</strong> <%= detail.borrow_id %></p>
  <p><strong>User:</strong> <%= detail.Borrow && detail.Borrow.User ? detail.Borrow.User.full_name : '-' %></p>
  <p><strong>Equipment:</strong> <%= detail.Equipment ? detail.Equipment.equipment_name : '-' %></p>
  <p><strong>Amount:</strong> <%= detail.amount %></p>
  <p><strong>Returned Amount:</strong> <%= detail.returned_amount %></p>
</div>
<%- include('../partials/footer') %>
