<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1>Create Borrow Detail</h1>
</div>
<div class="card">
  <form action="/borrow-details" method="POST" class="form-grid">
    <div class="form-group">
      <label for="borrow_id">Borrow Record</label>
      <select id="borrow_id" name="borrow_id" required>
        <option value="">Select borrow record</option>
        <% borrows.forEach((borrow) => { %>
          <option value="<%= borrow.id %>">#<%= borrow.id %> - <%= borrow.User ? borrow.User.full_name : 'Unknown' %> (<%= borrow.borrow_date %>)</option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="equipment_id">Equipment</label>
      <select id="equipment_id" name="equipment_id" required>
        <option value="">Select equipment</option>
        <% equipment.forEach((item) => { %>
          <option value="<%= item.id %>"><%= item.equipment_name %> (qty: <%= item.quantity %>)</option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="amount">Amount</label>
      <input id="amount" name="amount" type="number" min="1" required />
    </div>
    <div class="form-group">
      <label for="returned_amount">Returned Amount</label>
      <input id="returned_amount" name="returned_amount" type="number" min="0" value="0" />
    </div>
    <div class="actions">
      <button type="submit" class="btn btn-add">Create</button>
      <a class="btn btn-cancel" href="/borrow-details">Cancel</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
