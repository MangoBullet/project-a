<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1><%= currentUser && currentUser.role === 'admin' ? 'Borrow Records' : 'My Borrow Records' %></h1>
  <div class="actions">
    <a class="btn btn-add" href="/borrows/new"><%= currentUser && currentUser.role === 'admin' ? 'Add Borrow' : 'Borrow Equipment' %></a>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <a class="btn btn-primary" href="/borrow-details">Borrow Details</a>
    <% } %>
  </div>
</div>

<div class="card table-wrap">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>User</th>
        <th>Borrow Date</th>
        <th>Due Date</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% borrows.forEach((borrow) => { %>
        <tr>
          <td><%= borrow.id %></td>
          <td><%= borrow.User ? borrow.User.full_name : '-' %></td>
          <td><%= borrow.borrow_date %></td>
          <td><%= borrow.due_date %></td>
          <td><%= borrow.borrow_status %></td>
          <td class="actions">
            <a class="btn btn-primary" href="/borrows/<%= borrow.id %>">Show</a>
            <% if (currentUser && currentUser.role === 'admin') { %>
              <a class="btn btn-warning" href="/borrows/<%= borrow.id %>/edit">Edit</a>
              <form action="/borrows/<%= borrow.id %>?_method=DELETE" method="POST" data-confirm="Delete this borrow record?">
                <button class="btn btn-delete" type="submit">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
