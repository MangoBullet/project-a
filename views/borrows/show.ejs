<%- include('../partials/header', { title, path }) %>
<div class="page-header">
  <h1>Borrow Detail</h1>
  <div class="actions">
    <% if (currentUser && currentUser.role === 'admin') { %>
      <a class="btn btn-warning" href="/borrows/<%= borrow.id %>/edit">Edit</a>
    <% } %>
    <a class="btn btn-cancel" href="/borrows">Back</a>
  </div>
</div>

<div class="card">
  <p><strong>ID:</strong> <%= borrow.id %></p>
  <p><strong>User:</strong> <%= borrow.User ? borrow.User.full_name : '-' %></p>
  <p><strong>Borrow Date:</strong> <%= borrow.borrow_date %></p>
  <p><strong>Due Date:</strong> <%= borrow.due_date %></p>
  <p><strong>Status:</strong> <%= borrow.borrow_status %></p>
</div>

<div class="card" style="margin-top: 1rem;">
  <h2>Borrowed Items</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Borrow Detail ID</th>
          <th>Equipment</th>
          <th>Amount</th>
          <th>Returned Amount</th>
        </tr>
      </thead>
      <tbody>
        <% borrow.BorrowDetails.forEach((detail) => { %>
          <tr>
            <td><%= detail.id %></td>
            <td><%= detail.Equipment ? detail.Equipment.equipment_name : '-' %></td>
            <td><%= detail.amount %></td>
            <td><%= detail.returned_amount %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
